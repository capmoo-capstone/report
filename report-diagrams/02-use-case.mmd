flowchart LR
    %% Nexus Procure MVP - Use Case Diagram
    classDef actor fill:#ffffff,stroke:#334155,stroke-width:1.5px,color:#0f172a;
    classDef usecase fill:#eff6ff,stroke:#2563eb,stroke-width:1.4px,color:#0f172a;
    classDef group fill:#fffde7,stroke:#d6c94f,stroke-width:1px,color:#0f172a;

    Admin["Admin"]:::actor
    UnitRep["Representative"]:::actor
    Staff["General Staff"]:::actor
    FinStaff["Finance Staff"]:::actor
    DocStaff["Document Staff"]:::actor
    UHead["Head of Unit"]:::actor
    DHead["Head of Dept"]:::actor

    subgraph System["Nexus Procure MVP"]
        direction TB

        subgraph AdminCases["Admin Use Cases"]
            direction TB
            A1(["Manage Back Office Data"]):::usecase
            A2(["Configure delegation"]):::usecase
            A3(["Import budget plan"]):::usecase
        end

        subgraph UnitCases["Representative Use Cases"]
            direction TB
            U1(["Create project"]):::usecase
            U2(["View project timeline"]):::usecase
        end

        subgraph DocStaffCases["Document Staff Use Cases"]
            direction TB
            DS1(["Create project (Manual/Bulk)"]):::usecase
            DS2(["Propose submission for signature"]):::usecase
            DS3(["Sign and complete submission"]):::usecase
        end

        subgraph StaffCases["General Staff Use Cases"]
            direction TB
            GS1(["View assignment pool"]):::usecase
            GS2(["Self-pick job"]):::usecase
            GS3(["Confirm assigned job"]):::usecase
            GS4(["Update project workflow"]):::usecase
            GS5(["Upload and version documents"]):::usecase
            GS6(["Request cancellation"]):::usecase
            GS7(["Complete procurement / contract phase"]):::usecase
        end

        subgraph FinanceCases["Finance Staff Use Cases"]
            direction TB
            FS1(["Send bill submission form"]):::usecase
            FS2(["Submit to Finance Dept"]):::usecase
            FS3(["Close Project"]):::usecase
        end                       

        subgraph UHeadCases["Head of Unit Use Cases"]
            direction TB
            UH1(["Assign job"]):::usecase
            UH2(["Change or add assignee"]):::usecase
            UH3(["View workload distribution"]):::usecase
            UH4(["Return job for correction"]):::usecase
            UH5(["Approve submission"]):::usecase
            UH6(["Approve or reject cancellation"]):::usecase
        end

        subgraph DHeadCases["Head of Dept Use Cases"]
            direction TB
            DH1(["View workload distribution"]):::usecase
            DH2(["Approve or reject cancellation"]):::usecase
        end
    end

    Admin --> A1
    Admin --> A2
    Admin --> A3

    UnitRep --> U1
    UnitRep --> U2

    DocStaff --> DS1
    DocStaff --> DS2
    DocStaff --> DS3

    Staff --> GS1
    Staff --> GS2
    Staff --> GS3
    Staff --> GS4
    Staff --> GS5
    Staff --> GS6
    Staff --> GS7

    FinStaff --> FS1
    FinStaff --> FS2
    FinStaff --> FS3

    UHead --> UH1
    UHead --> UH2
    UHead --> UH3
    UHead --> UH4
    UHead --> UH5
    UHead --> UH6

    DHead --> DH1
    DHead --> DH2