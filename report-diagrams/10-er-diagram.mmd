erDiagram
    UNIT ||--o{ USER : contains
    ROLE ||--o{ USER : grants
    USER ||--o{ DELEGATION : delegates_from
    USER ||--o{ DELEGATION : delegates_to
    UNIT ||--o{ BUDGET_PLAN : owns
    UNIT ||--o{ PROJECT : requests
    USER ||--o{ PROJECT : creates
    PROJECT ||--o{ PROJECT_BUDGET_PLAN : links
    BUDGET_PLAN ||--o{ PROJECT_BUDGET_PLAN : selected_for
    PROJECT ||--o{ ASSIGNMENT : has
    USER ||--o{ ASSIGNMENT : responsible_for
    PROJECT ||--o{ WORKFLOW_STEP : contains
    WORKFLOW_STEP ||--o{ DOCUMENT : requires
    DOCUMENT ||--o{ DOCUMENT_VERSION : versions
    USER ||--o{ DOCUMENT_VERSION : uploads
    PROJECT ||--o| CONTRACT_NUMBER : receives
    PROJECT ||--o| ASSET_RECORD : checks
    PROJECT ||--o{ CANCELLATION_REQUEST : may_have
